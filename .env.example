# Environment Variables for ElectraGuide

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ──────────────────────────────────
# Replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/electraguide

# ── JWT ────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRES_IN=7d

# ── Vote Hashing ───────────────────────────────────
VOTE_HASH_SECRET=your_vote_hash_secret_change_this

# ── Frontend ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin Registration ─────────────────────────────
# Set to 'true' only when creating first admin account
ALLOW_ADMIN_REGISTER=false

# ── Nodemailer (Optional OTP) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
