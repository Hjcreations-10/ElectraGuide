# Environment Variables for ElectraGuide

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ──────────────────────────────────
# Paste your Atlas connection string here in Vercel/Local .env
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/electraguide

# ── JWT ────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRES_IN=7d

# ── Vote Hashing ───────────────────────────────────
VOTE_HASH_SECRET=your_vote_hash_secret

# ── Frontend ───────────────────────────────────────
# Use / for Vercel deployment
FRONTEND_URL=/

# ── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin Registration ─────────────────────────────
# Set to 'true' only when creating first admin account
ALLOW_ADMIN_REGISTER=false

# ── Nodemailer (Optional OTP) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
